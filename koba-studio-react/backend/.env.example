# ============================================================
# KoBa Studio Backend — Variables de entorno
# Copiar como .env y completar los valores.
# NUNCA subir .env a git.
# ============================================================

# ── Servidor ─────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# En producción (Railway/Render):
# FRONTEND_URL=https://kobastudio.com
# BACKEND_URL=https://api.kobastudio.com

# ── Supabase ──────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️ Usar el SERVICE ROLE key (no el anon key) — bypasea RLS para webhook

# ── Resend (Email) ────────────────────────────
# Crear cuenta en resend.com (gratis hasta 3000 emails/mes)
# Verificar tu dominio en Resend → Domains → Add Domain
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_DOMAIN=kobastudio.com
CONTACT_EMAIL=hola@kobastudio.com

# ── Mercado Pago ──────────────────────────────
# Obtener en: mercadopago.cl → Tu negocio → Credenciales
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_CURRENCY=CLP
# Para pruebas usar el Access Token de TEST (empieza con TEST-)
