# Backend de KOBA-STUDIO — Variables de Entorno
# Copiar a .env.local y llenar con valores reales

# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Frontend
FRONTEND_URL=http://localhost:5173

# JWT (para verificación adicional)
JWT_SECRET=your-jwt-secret

# Correo electrónico (para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=hola@kobastudio.com

# Payment Gateway (Mercado Pago)
MP_ACCESS_TOKEN=your-mercado-pago-token
MP_WEBHOOK_SECRET=your-webhook-secret

# Base de datos (si usas otra además de Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/koba-studio
